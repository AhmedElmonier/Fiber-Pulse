# FiberPulse Environment Configuration
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/fiberpulse

# Currency API (for USD conversion)
CURRENCY_RATE_API_KEY=your_currency_api_key

# Application Settings
TIMEZONE=Africa/Cairo
LOG_LEVEL=INFO

# Data Source Credentials (optional)
# DATA_SOURCE_CREDENTIALS={"cai_spot": "api_key", "mcx_futures": "credentials"}

# Telegram Integration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WHITELIST=user_id_1,user_id_2,user_id_3  # Comma-separated Chat IDs